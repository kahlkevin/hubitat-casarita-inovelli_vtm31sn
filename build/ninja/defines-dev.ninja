# User macros for dev flavor.
gpp_macros = $
    -DINCLIB="#include @NAMESPACE.#1"

# Unset feature switches
gpp_not_currently_set = $
    -DDEFMOVERATE_SUPPORT $
    -DENABLE_DEBUG_DISPATCH $
    -DENABLE_DEBUG_EVENTS $
    -DENABLE_DEBUG_HEOBJS $
    -DENABLE_DEBUG_MODESELECT $
    -DENABLE_DEBUG_PREFS $
    -DENABLE_DEBUG_SUBS $
    -DENABLE_PARSER_NUM_HISTO $
    -DENABLE_PARSER_TYPE_RETURN $
    -DENABLE_TESTS_FOR_MODESELECT $
    -DENABLE_TESTS_FOR_PARSER $
    -DINCLUDE_HUBITAT_PARSE_OUTPUT $
    -DNO_LOG_STYLING $

# Feature switches for dev flavor.
gpp_defs = $
    -DENABLE_ATTRIBUTE_PASSIVE_CACHE $
    -DENABLE_ATTRIBUTE_SCAN_AND_SAVE $
    -DENABLE_BLACK_BOX $
    -DENABLE_DEBUG_TRIGGER_SUPPORT $
    -DENABLE_DISTCLEAN_SUPPORT $
    -DEVENT_SEQUENCING=reorder $
    -DSORT_SUBSCRIPTION_PATHS $

# eof
